# ============================================================
# PaperMind Backend - Variables de entorno
# ============================================================

# Servidor local
HOST=127.0.0.1
PORT=8080

# Supabase / PostgreSQL
# Supabase > Project Settings > Database > Connection string > URI
DATABASE_URL=postgres://postgres:TU_PASSWORD@db.TU_PROJECT_REF.supabase.co:5432/postgres
SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=tu_anon_key


# OpenRouter - agentes IA reales
# https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-tu_api_key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:8080
OPENROUTER_APP_NAME=PaperMind

# Mailing gratuito recomendado: Resend
# https://resend.com/api-keys
RESEND_API_KEY=re_tu_api_key
# En Resend, para pruebas puedes usar el dominio permitido por tu cuenta o un dominio verificado.
MAIL_FROM=PaperMind <noreply@tu-dominio.com>
